    {
      "type": "quantity_discounts",
      "name": "Quantity Discounts",
      "limit": 1,
      "settings": [
        {
          "type": "checkbox",
          "id": "enabled",
          "label": "Enable quantity discounts",
          "default": true
        },
        {
          "type": "text",
          "id": "title",
          "label": "Section title",
          "default": "Buy More, Save More"
        },
        {
          "type": "text",
          "id": "subtitle",
          "label": "Section subtitle",
          "default": "Get a better deal when you order in bulk"
        },
        {
          "type": "select",
          "id": "discount_type",
          "label": "Discount type",
          "options": [
            { "value": "percentage", "label": "Percentage off" },
            { "value": "fixed_amount", "label": "Fixed amount off per item" },
            { "value": "fixed_price", "label": "Fixed price per item" }
          ],
          "default": "percentage"
        },
        {
          "type": "checkbox",
          "id": "show_savings",
          "label": "Show savings amounts",
          "default": true
        },
        {
          "type": "checkbox",
          "id": "show_per_unit",
          "label": "Show per-unit price",
          "default": true
        },
        {
          "type": "checkbox",
          "id": "highlight_best",
          "label": "Highlight best value tier",
          "default": true
        },
        {
          "type": "checkbox",
          "id": "apply_to_cart",
          "label": "Attach discount info to cart line items",
          "default": true,
          "info": "Adds discount metadata as line item properties."
        },
        {
          "type": "text",
          "id": "badge_text",
          "label": "Default badge text",
          "default": "SAVE",
          "info": "Badge shown on the best-value tier"
        },
        {
          "type": "select",
          "id": "table_style",
          "label": "Display style",
          "options": [
            { "value": "cards", "label": "Cards" },
            { "value": "table", "label": "Table" },
            { "value": "pills", "label": "Quick-select pills" }
          ],
          "default": "cards"
        },
        {
          "type": "color",
          "id": "accent_color",
          "label": "Accent color",
          "default": "#4a6cf7"
        },
        {
          "type": "header",
