{% comment %}
  Quantity Discount Settings Section
  Add this to your theme's sections/ directory.
  Then include it in your product template to enable quantity-based pricing.
{% endcomment %}

<div
  id="qty-discount-section"
  data-section-id="{{ section.id }}"
  data-product-id="{{ product.id }}"
  data-product-price="{{ product.selected_or_first_available_variant.price }}"
  data-product-compare-price="{{ product.selected_or_first_available_variant.compare_at_price }}"
  data-currency="{{ cart.currency.iso_code }}"
  data-money-format="{{ shop.money_format }}"
  style="display:none;"
>
  {%- comment -%} Serialize discount tiers from section settings {%- endcomment -%}
  <script type="application/json" id="qty-discount-config-{{ section.id }}">
    {
      "enabled": {{ section.settings.enabled | json }},
      "title": {{ section.settings.title | json }},
      "subtitle": {{ section.settings.subtitle | json }},
      "discount_type": {{ section.settings.discount_type | json }},
      "show_savings": {{ section.settings.show_savings | json }},
      "show_per_unit": {{ section.settings.show_per_unit | json }},
      "highlight_best": {{ section.settings.highlight_best | json }},
      "apply_to_cart": {{ section.settings.apply_to_cart | json }},
      "badge_text": {{ section.settings.badge_text | json }},
      "table_style": {{ section.settings.table_style | json }},
      "accent_color": {{ section.settings.accent_color | json }},
      "tiers": [
        {%- for block in section.blocks -%}
          {%- if block.type == 'tier' -%}
            {
              "min_qty": {{ block.settings.min_qty | json }},
              "max_qty": {{ block.settings.max_qty | default: 0 | json }},
              "discount_value": {{ block.settings.discount_value | json }},
              "label": {{ block.settings.label | json }},
              "badge": {{ block.settings.badge | json }}
            }{%- unless forloop.last -%},{%- endunless -%}
          {%- endif -%}
        {%- endfor -%}
      ]
    }
  </script>
</div>

{% schema %}
{
  "name": "Quantity Discounts",
  "tag": "section",
  "class": "qty-discount-section",
  "settings": [
    {
      "type": "checkbox",
      "id": "enabled",
      "label": "Enable quantity discounts",
      "default": true
    },
    {
      "type": "text",
      "id": "title",
      "label": "Section title",
      "default": "Buy More, Save More"
    },
    {
      "type": "text",
      "id": "subtitle",
      "label": "Section subtitle",
      "default": "Get a better deal when you order in bulk"
    },
    {
      "type": "select",
      "id": "discount_type",
      "label": "Discount type",
      "options": [
        { "value": "percentage", "label": "Percentage off" },
        { "value": "fixed_amount", "label": "Fixed amount off per item" },
        { "value": "fixed_price", "label": "Fixed price per item" }
      ],
      "default": "percentage"
    },
    {
      "type": "checkbox",
      "id": "show_savings",
      "label": "Show total savings",
      "default": true
    },
    {
      "type": "checkbox",
      "id": "show_per_unit",
      "label": "Show per-unit price",
      "default": true
    },
    {
      "type": "checkbox",
      "id": "highlight_best",
      "label": "Highlight best value tier",
      "default": true
    },
    {
      "type": "checkbox",
      "id": "apply_to_cart",
      "label": "Apply discount in cart (via line item properties)",
      "default": true,
      "info": "Requires Shopify Scripts or a compatible discount app for actual price adjustment at checkout."
    },
    {
      "type": "text",
      "id": "badge_text",
      "label": "Default badge text",
      "default": "SAVE",
      "info": "Shown next to discount tiers"
    },
    {
      "type": "select",
      "id": "table_style",
      "label": "Display style",
      "options": [
        { "value": "table", "label": "Table" },
        { "value": "cards", "label": "Cards" },
        { "value": "pills", "label": "Quick-select pills" }
      ],
      "default": "cards"
    },
    {
      "type": "color",
      "id": "accent_color",
      "label": "Accent color",
      "default": "#4a6cf7"
    }
  ],
  "blocks": [
    {
      "type": "tier",
      "name": "Discount Tier",
      "settings": [
        {
          "type": "number",
          "id": "min_qty",
          "label": "Minimum quantity",
          "default": 2
        },
        {
          "type": "number",
          "id": "max_qty",
          "label": "Maximum quantity (0 = unlimited)",
          "default": 0
        },
        {
          "type": "number",
          "id": "discount_value",
          "label": "Discount value",
          "default": 10,
          "info": "Percentage, fixed amount off, or fixed price — depends on Discount Type setting above."
        },
        {
          "type": "text",
          "id": "label",
          "label": "Tier label",
          "default": "",
          "info": "Optional. e.g. 'Starter Pack', 'Best Value'. Leave blank for auto-generated label."
        },
        {
          "type": "text",
          "id": "badge",
          "label": "Tier badge",
          "default": "",
          "info": "Optional. e.g. 'POPULAR', 'BEST DEAL'. Leave blank for default badge."
        }
      ]
    }
  ],
  "presets": [
    {
      "name": "Quantity Discounts",
      "blocks": [
        {
          "type": "tier",
          "settings": {
            "min_qty": 2,
            "max_qty": 4,
            "discount_value": 5,
            "label": "",
            "badge": ""
          }
        },
        {
          "type": "tier",
          "settings": {
            "min_qty": 5,
            "max_qty": 9,
            "discount_value": 10,
            "label": "",
            "badge": ""
          }
        },
        {
          "type": "tier",
          "settings": {
            "min_qty": 10,
            "max_qty": 24,
            "discount_value": 15,
            "label": "",
            "badge": "POPULAR"
          }
        },
        {
          "type": "tier",
          "settings": {
            "min_qty": 25,
            "max_qty": 0,
            "discount_value": 20,
            "label": "Best Value",
            "badge": "BEST DEAL"
          }
        }
      ]
    }
  ]
}
{% endschema %}
